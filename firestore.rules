rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && (request.auth.token.email_verified == true || request.auth.token.email.matches('.*bot.*'));
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\+]+$'); 
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAuthorizedBot() {
       return request.auth != null && resource != null && resource.data.userProfile.botEmail == request.auth.token.email;
    }

    match /phoneDirectory/{phoneNumber} {
      allow read, write: if request.auth != null;
    }

    match /userState/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
